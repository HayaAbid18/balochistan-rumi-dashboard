{
  "buildCommand": "next build",
  "devCommand": "next dev",
  "outputDirectory": ".next",
  "env": [
    {
      "key": "DB_HOST",
      "value": "@db_host",
      "type": "secret"
    },
    {
      "key": "DB_PORT",
      "value": "5432",
      "type": "plain"
    },
    {
      "key": "DB_NAME",
      "value": "postgres",
      "type": "plain"
    },
    {
      "key": "DB_USER",
      "value": "@db_user",
      "type": "secret"
    },
    {
      "key": "DB_PASSWORD",
      "value": "@db_password",
      "type": "secret"
    }
  ],
  "functions": {
    "pages/api/**": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
